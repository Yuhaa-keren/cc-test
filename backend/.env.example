# ============================================
# Konfigurasi Database MySQL (Instance Terpisah)
# ============================================
# Ganti dengan Private IP dari EC2 Database
DB_HOST=10.0.1.100
DB_USER=root
DB_PASSWORD=password_kamu_disini
DB_NAME=db_tubes

# ============================================
# Identifikasi Server untuk Load Balancer
# ============================================
# Set "1" di EC2 Webserver 1, set "2" di EC2 Webserver 2
SERVER_ID=1
